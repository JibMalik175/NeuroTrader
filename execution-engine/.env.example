# ═══════════════════════════════════════════════════════════════════
#  TradeBot Execution Engine — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#  Copy this file to `.env` and fill in your values.
#  DO NOT commit your .env file — it contains secrets.
# ═══════════════════════════════════════════════════════════════════

# ── Execution Mode ─────────────────────────────────────────────────
# MOCK_MODE=true   → safest, zero API calls, simulated everything
# PAPER_TRADE=true → real market data, virtual balance, no real orders
# (both false)     → LIVE trading with real money — use with caution!
MOCK_MODE=true
PAPER_TRADE=false

# ── Binance API ────────────────────────────────────────────────────
# Required only for LIVE mode. MOCK and PAPER do not place real orders.
# Create keys at https://www.binance.com/en/my/settings/api-management
# NEVER enable withdrawal permissions on the trading key.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Use Binance testnet instead of production (recommended for PAPER)
# https://testnet.binance.vision/
USE_TESTNET=false

# ── Trading Parameters ────────────────────────────────────────────
# Trading pair in CCXT format (e.g. BTC/USDT, ETH/USDT)
TRADING_PAIR=BTC/USDT

# Candle timeframe (1m, 5m, 15m, 1h, 4h, 1d)
TIMEFRAME=1h

# Number of feature candles fed to the AI model.
# Must match ai-training/scripts/train_agent.py ENV_CONFIG["window_size"].
WINDOW_SIZE=48

# ── Risk Management ───────────────────────────────────────────────
# Stop-loss percentage below entry price (0.015 = 1.5%)
STOP_LOSS_PCT=0.015

# Take-profit percentage above entry price (0.03 = 3.0%)
TAKE_PROFIT_PCT=0.03

# Max portfolio fraction risked per trade (0.02 = 2%)
MAX_RISK_PER_TRADE=0.02

# Minimum AI confidence to enter a trade (0.6 = 60%)
MIN_CONFIDENCE=0.6

# ── AI Model ──────────────────────────────────────────────────────
# Path to the ONNX model file.
# Leave empty to use the default: src/strategist/models/tradebot.onnx
MODEL_PATH=

# ── Database ──────────────────────────────────────────────────────
# MongoDB connection string (used for trade persistence & dashboard)
MONGO_URI=mongodb://localhost:27017/tradebot

# ── Telegram Notifications ────────────────────────────────────────
# Optional: get real-time alerts on trades and errors.
# Create a bot via @BotFather and get your chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=info
