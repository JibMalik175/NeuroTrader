{
  "name": "tradebot-execution-engine",
  "version": "1.0.0",
  "description": "AI-powered cryptocurrency trading bot — execution engine",
  "main": "dist/index.js",
  "scripts": {
    "start": "node -r dotenv/config dist/index.js",
    "mock": "cross-env MOCK_MODE=true ts-node src/index.ts",
    "paper": "cross-env PAPER_TRADE=true ts-node src/index.ts",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "parity": "ts-node src/strategist/verifyParity.ts"
  },
  "keywords": [
    "trading",
    "bot",
    "binance",
    "onnx",
    "ai"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "ccxt": "^4.4.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "mongoose": "^8.9.0",
    "onnxruntime-node": "^1.20.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
