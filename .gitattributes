# Normalize line endings: LF in the repo, native on checkout.
* text=auto

# Always LF — tooling that reads these is LF-sensitive
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — never touch
*.zip   binary
*.pkl   binary
*.parquet binary
*.onnx  binary
*.png   binary
*.jpg   binary
